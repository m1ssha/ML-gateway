# === PostgreSQL ===
POSTGRES_USER=gateway
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=llm_gateway

# === Backend ===
DATABASE_URL=postgresql+asyncpg://gateway:change_me_in_production@postgres:5432/llm_gateway
REDIS_URL=redis://redis:6379/0
ML_SERVICE_URL=http://ml-service:8000
ML_SERVICE_TIMEOUT=2.0
LLM_PROVIDER=openrouter
LLM_MODEL=qwen/qwen3.6-35b-a3b
LLM_TIMEOUT=15.0
LLM_MAX_RETRIES=1

# API Keys
OPENAI_API_KEY=
YANDEX_API_KEY=
OPENROUTER_API_KEY=
HTTP_REFERER=https://llm-gateway.local
APP_TITLE=LLM Security Gateway Prototype
THRESHOLD_LOW=0.30
THRESHOLD_HIGH=0.70
CUMULATIVE_THRESHOLD=0.50

# === Frontend (production) ===
VITE_API_BASE_URL=
VITE_APP_TITLE=LLM Gateway
VITE_SHOW_RISK_DETAILS=true

# === Ports ===
NGINX_HTTP_PORT=80
POSTGRES_PORT=5432
REDIS_PORT=6379
