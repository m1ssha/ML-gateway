# App Settings
APP_NAME="ML Gateway"
DEBUG=True

# Database
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/ml_gateway"

# Redis
REDIS_URL="redis://localhost:6379/0"

# ML Service
ML_SERVICE_URL="http://ml-service:8001/predict"

# LLM Provider
LLM_PROVIDER="openrouter"  # mock, openai, yandex, gigachat, openrouter
LLM_MODEL="qwen/qwen3.6-35b-a3b"
LLM_TIMEOUT=15.0
LLM_MAX_RETRIES=1

# OpenAI Credentials
OPENAI_API_KEY="sk-..."

# OpenRouter Credentials
OPENROUTER_API_KEY="sk-or-v1-..."
HTTP_REFERER="https://llm-gateway.local"
APP_TITLE="LLM Security Gateway Prototype"

# Gateway Thresholds
THRESHOLD_LOW=0.30
THRESHOLD_HIGH=0.70
CUMULATIVE_THRESHOLD=0.50
CUMULATIVE_BLOCK_THRESHOLD=1.0
CUMULATIVE_SESSIONS_BLOCK_THRESHOLD=1.5
