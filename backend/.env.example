# App Settings
APP_NAME="ML Gateway"
DEBUG=True

# Database
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/ml_gateway"

# Redis
REDIS_URL="redis://localhost:6379/0"

# ML Service
ML_SERVICE_URL="http://ml-service:8001/predict"

# LLM Provider
LLM_PROVIDER="mock"  # mock, openai, yandex, gigachat
OPENAI_API_KEY="sk-..."

# Gateway Thresholds
THRESHOLD_LOW=0.30
THRESHOLD_HIGH=0.70
CUMULATIVE_THRESHOLD=0.50
CUMULATIVE_BLOCK_THRESHOLD=1.0
CUMULATIVE_SESSIONS_BLOCK_THRESHOLD=1.5
